  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "bun run build.ts",
    "build:types": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run typecheck && bun run build && bun run test",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "app": "cd test-app && bun run dev",
    "app:i": "cd test-app && bun i"
  },
  "keywords": [
    "sinwan",
    "reactive",
    "ui",
    "ssr",
    "hydration",
    "jsx",
    "signals",
    "components",
    "framework",
    "bun"
  ],
